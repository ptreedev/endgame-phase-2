#cloud-config
package_update: true
packages:
  - nginx
  - git
  - docker.io
  - docker-compose-v2

write_files:
  - path: /etc/nginx/sites-available/my-site.conf
    permissions: '0644'
    content: |
      server {
        listen 80;
        server_name _;

        location / {
            proxy_pass http://127.0.0.1:5000;
            proxy_set_header Host $host;
            proxy_set_header X-Real-IP $remote_addr;
            proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
            proxy_set_header X-Forwarded-Proto $scheme;
        }
      }

runcmd:
  - ln -s /etc/nginx/sites-available/my-site.conf /etc/nginx/sites-enabled/
  - rm /etc/nginx/sites-enabled/default
  - systemctl restart nginx
  - systemctl start docker
  - systemctl enable docker
  - usermod -aG docker ubuntu
  - sudo -u ubuntu git clone https://github.com/ptreedev/endgame-phase-2 /home/ubuntu/endgame-phase-2
  - chown -R ubuntu:ubuntu /home/ubuntu/endgame-phase-2
  - |
    cat > /home/ubuntu/endgame-phase-2/.env << 'EOF'
    API_BASE_URL=${API_URL}
    EOF
  - chmod 600 /home/ubuntu/endgame-phase-2/.env
  - chown ubuntu:ubuntu /home/ubuntu/endgame-phase-2/.env
  - cd /home/ubuntu/endgame-phase-2 && docker compose up -d --build